datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

enum SizeType {
  LETTERED
  NUMBERED
  CUSTOM
}

enum TokenType {
  EMAIL_VERIFY
  PASSWORD_RESET
}

// Motorcycle Equipment Enums
enum Category {
  HELMETS
  JACKETS
  PANTS
  GLOVES
  BOOTS
  PROTECTORS
  THERMALS
  EYEWEAR
  RAINGEAR
  BAGS
  ACCESSORIES
}

enum Condition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
}

enum Gender {
  UNISEX
  MEN
  WOMEN
}

// NextAuth Tables
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  passwordHash  String?
  role          Role      @default(USER)
  image         String?
  accounts      Account[]
  sessions      Session[]
  favorites     Favorite[]
  auditLogs     AuditLog[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(cuid())
  email      String
  token      String   @unique
  expires    DateTime
  type       TokenType

  @@unique([email, token])
}

// E-commerce Tables
model Brand {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  logoUrl   String?
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id            String    @id @default(cuid())
  brandId       String
  name          String
  slug          String    @unique
  description   String    @db.Text
  material      String?
  sizeType      SizeType
  basePrice     Float
  images        Json      // Array of image URIs
  isOnSale      Boolean   @default(false)
  salePrice     Float?
  campaignMonth Int?

  // Motorcycle Equipment Specifics
  category      Category  @default(HELMETS)
  condition     Condition?
  gender        Gender?
  season        String?      // e.g., "Yaz", "Kış", "Dört Mevsim"
  
  // Category-Specific Dynamic Fields
  helmetType    String?      // e.g., "Full Face", "Modular", "Open Face"
  certification String?      // e.g., "DOT", "ECE", "Snell"
  
  brand         Brand     @relation(fields: [brandId], references: [id])
  variants      ProductVariant[]
  favorites     Favorite[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ProductVariant {
  id            String    @id @default(cuid())
  productId     String
  colorName     String
  colorHex      String
  size          String
  stock         Int       @default(0)
  price         Float
  salePrice     Float?
  
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  subscriptions StockSubscription[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@unique([productId, colorName, size])
}

model Favorite {
  id                String    @id @default(cuid())
  userId            String
  productId         String
  lastNotifiedPrice Float?
  
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  product           Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt         DateTime  @default(now())
  
  @@unique([userId, productId])
}

model StockSubscription {
  id               String         @id @default(cuid())
  email            String
  productVariantId String
  
  variant          ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  createdAt        DateTime       @default(now())
  notifiedAt       DateTime?
  
  @@unique([email, productVariantId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String
  oldValue  Json?
  newValue  Json?
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model CampaignBanner {
  id        String   @id @default(cuid())
  month     Int
  year      Int
  title     String
  subtitle  String?
  imageUrl  String
  isActive  Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
